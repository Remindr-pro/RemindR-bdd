# Server Configuration
NODE_ENV=production
PORT=3000
API_VERSION=v1

# Database - Use strong passwords in production!
POSTGRES_USER=remindr_prod
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_DB=remindr_db_prod
DATABASE_URL=postgresql://remindr_prod:CHANGE_THIS_STRONG_PASSWORD@postgres:5432/remindr_db_prod?schema=public

# JWT Configuration - Generate strong secrets!
JWT_SECRET=CHANGE_THIS_TO_A_VERY_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_THIS_TO_A_VERY_STRONG_RANDOM_SECRET
JWT_REFRESH_EXPIRES_IN=30d

# OAuth2 Configuration
OAUTH2_GOOGLE_CLIENT_ID=your-google-client-id
OAUTH2_GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH2_GOOGLE_REDIRECT_URI=https://remind-r.com/api/v1/auth/google/callback

OAUTH2_APPLE_CLIENT_ID=your-apple-client-id
OAUTH2_APPLE_CLIENT_SECRET=your-apple-client-secret
OAUTH2_APPLE_REDIRECT_URI=https://remind-r.com/api/v1/auth/apple/callback

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_THIS_STRONG_REDIS_PASSWORD

# Firebase Cloud Messaging
FCM_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json
FCM_PROJECT_ID=your-fcm-project-id

# SendGrid Email
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@remind-r.com

# Twilio SMS
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Frontend URL (for password reset and activation links)
FRONTEND_URL=https://remind-r.com

# CORS - Update with your production frontend URL
CORS_ORIGIN=https://remind-r.com,https://www.remind-r.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Sentry Error Tracking
SENTRY_DSN=your-sentry-dsn-here

# Database Backup
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
BACKUP_CRON_SCHEDULE=0 2 * * *

