{
  "name": "remindr-api",
  "version": "1.0.0",
  "description": "API Backend for RemindR health application",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "node scripts/kill-port.js 3000 && node scripts/start-services.js && tsx watch src/server.ts",
    "dev:no-redis": "node scripts/kill-port.js 3000 && node scripts/start-services.js && tsx watch src/server.ts",
    "dev:no-services": "node scripts/kill-port.js 3000 && tsx watch src/server.ts",
    "build": "tsc",
    "start": "node scripts/start-server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "services:start": "docker-compose up postgres redis -d",
    "services:stop": "docker-compose stop postgres redis",
    "services:logs": "docker-compose logs -f",
    "redis:start": "docker-compose up redis -d",
    "redis:stop": "docker-compose stop redis",
    "redis:logs": "docker-compose logs -f redis",
    "postgres:start": "docker-compose up postgres -d",
    "postgres:stop": "docker-compose stop postgres",
    "postgres:logs": "docker-compose logs -f postgres",
    "postgres:reset": "node scripts/reset-db.js",
    "db:check": "node scripts/check-db.js",
    "db:fix-password": "node scripts/fix-db-password.js",
    "db:setup": "npm run postgres:start && timeout /t 5 /nobreak >nul && npm run prisma:migrate",
    "db:backup": "node scripts/backup-db.js",
    "db:backup:setup": "node scripts/setup-backup-cron.js",
    "kill:port": "node scripts/kill-port.js",
    "monitoring:start": "docker-compose -f docker-compose.monitoring.yml up -d",
    "monitoring:stop": "docker-compose -f docker-compose.monitoring.yml down",
    "monitoring:logs": "docker-compose -f docker-compose.monitoring.yml logs -f",
    "generate:secrets": "node scripts/generate-secrets.js",
    "deploy": "node scripts/deploy.js",
    "deploy:prod": "./scripts/deploy-production.sh",
    "backup:db": "./scripts/backup-db.sh",
    "env:check": "node scripts/check-env.js",
    "start:pm2": "pm2 start ecosystem.config.js",
    "pm2:logs": "pm2 logs remindr-api",
    "pm2:restart": "pm2 restart remindr-api",
    "pm2:stop": "pm2 stop remindr-api",
    "pm2:status": "pm2 status",
    "clean": "node scripts/clean.js",
    "clean:all": "node scripts/clean.js --all && npm cache clean --force",
    "clean:build": "node scripts/clean.js",
    "clean:cache": "node scripts/clean.js",
    "clean:prisma": "node scripts/clean.js"
  },
  "keywords": [
    "health",
    "reminders",
    "api",
    "express",
    "prisma"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "@sendgrid/mail": "^8.1.0",
    "@sentry/node": "^10.37.0",
    "@sentry/profiling-node": "^10.37.0",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "bcrypt": "^5.1.1",
    "bull": "^4.12.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "firebase-admin": "^12.7.0",
    "helmet": "^7.2.0",
    "ioredis": "^5.9.2",
    "jose": "^6.1.3",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.3",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.17.2",
    "pino": "^10.3.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^4.23.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^25.1.0",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "globals": "^17.2.0",
    "jest": "^30.2.0",
    "prisma": "^6.1.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
