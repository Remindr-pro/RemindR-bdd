{
  "name": "remindr-api",
  "version": "1.0.0",
  "description": "API Backend for RemindR health application",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node scripts/start-services.js && tsx watch src/server.ts",
    "dev:no-redis": "node scripts/start-services.js && tsx watch src/server.ts",
    "dev:no-services": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "services:start": "docker-compose up postgres redis -d",
    "services:stop": "docker-compose stop postgres redis",
    "services:logs": "docker-compose logs -f",
    "redis:start": "docker-compose up redis -d",
    "redis:stop": "docker-compose stop redis",
    "redis:logs": "docker-compose logs -f redis",
    "postgres:start": "docker-compose up postgres -d",
    "postgres:stop": "docker-compose stop postgres",
    "postgres:logs": "docker-compose logs -f postgres",
    "postgres:reset": "node scripts/reset-db.js",
    "db:check": "node scripts/check-db.js",
    "db:fix-password": "node scripts/fix-db-password.js",
    "db:setup": "npm run postgres:start && timeout /t 5 /nobreak >nul && npm run prisma:migrate",
    "kill:port": "node scripts/kill-port.js"
  },
  "keywords": [
    "health",
    "reminders",
    "api",
    "express",
    "prisma"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@sendgrid/mail": "^8.1.0",
    "bcrypt": "^5.1.1",
    "bull": "^4.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "firebase-admin": "^12.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "twilio": "^4.20.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prisma": "^6.19.0",
    "ts-jest": "^29.4.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
